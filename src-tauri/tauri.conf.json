{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Discord Clone",
  "identifier": "com.discord.clone",
  "version": "1.0.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Discord Clone",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    },
    "publisher": "Developer",
    "shortDescription": "Discord Clone App"
  }
}
